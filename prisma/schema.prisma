// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

enum WorkspaceRole {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}


enum ConversationStatus {
  OPEN
  SNOOZED
  CLOSED
}

enum MessageType {
  VISITOR
  AGENT
  NOTE
  SYSTEM
  BOT
}

// ─── Auth Models ─────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map(name: "created_at")
  updatedAt         DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  updatedAt     DateTime  @default(now()) @map(name: "updated_at")
  role          UserRole  @default(USER)

  accounts             Account[]
  sessions             Session[]
  workspaceMembers     WorkspaceMember[]
  sentInvitations      WorkspaceInvitation[]
  messages             Message[]
  articles             Article[]

  @@map(name: "users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map(name: "password_reset_tokens")
}

// ─── Workspace & Organization Models ────────────────────

model Workspace {
  id                   String           @id @default(cuid())
  name                 String
  slug                 String           @unique
  logo                 String?
  appId                String           @unique @default(cuid())
  createdAt            DateTime         @default(now()) @map(name: "created_at")
  updatedAt            DateTime         @updatedAt @map(name: "updated_at")

  members            WorkspaceMember[]
  invitations        WorkspaceInvitation[]
  conversations      Conversation[]
  visitors           Visitor[]
  articles           Article[]
  collections        Collection[]
  widgetSettings     WidgetSettings?
  helpCenterSettings HelpCenterSettings?
  cannedResponses    CannedResponse[]
  aiUsageLogs        AiUsageLog[]
  automationRules    AutomationRule[]
  slackIntegration   SlackIntegration?
  analyticsSnapshots AnalyticsSnapshot[]
  slaPolicies        SlaPolicy[]
  slaTimers          SlaTimer[]

  @@map(name: "workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(AGENT)
  createdAt   DateTime      @default(now()) @map(name: "created_at")
  updatedAt   DateTime      @updatedAt @map(name: "updated_at")

  workspace             Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map(name: "workspace_members")
}

model WorkspaceInvitation {
  id          String           @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole    @default(AGENT)
  status      InvitationStatus @default(PENDING)
  token       String           @unique @default(cuid())
  expiresAt   DateTime
  invitedById String
  createdAt   DateTime         @default(now()) @map(name: "created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@map(name: "workspace_invitations")
}

// ─── Widget Settings ─────────────────────────────────────

model WidgetSettings {
  id               String   @id @default(cuid())
  workspaceId      String   @unique
  primaryColor     String   @default("#3ECF8E")
  position         String   @default("bottom-right")
  welcomeMessage   String   @default("Hi! How can we help you?")
  workspaceName    String?
  workspaceAvatarUrl String?
  showBranding     Boolean  @default(true)
  requireEmail     Boolean  @default(false)
  suggestArticles    Boolean  @default(true)
  offlineFormTimeout Int?     @map(name: "offline_form_timeout") // minutes — null means disabled
  pageVisibilityMode    String @default("exclude") // "exclude" or "include"
  pageVisibilityPatterns Json   @default("[]")      // JSON array of glob-pattern strings
  createdAt          DateTime @default(now()) @map(name: "created_at")
  updatedAt          DateTime @updatedAt @map(name: "updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map(name: "widget_settings")
}

// ─── Visitor & Conversation Models ───────────────────────

model Visitor {
  id         String   @id @default(cuid())
  workspaceId String
  externalId String?
  name       String?
  email      String?
  avatarUrl  String?
  metadata   Json?
  lastSeenAt DateTime?
  createdAt  DateTime @default(now()) @map(name: "created_at")
  updatedAt  DateTime @updatedAt @map(name: "updated_at")

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([workspaceId, externalId])
  @@index([workspaceId])
  @@map(name: "visitors")
}

model Conversation {
  id                 String             @id @default(cuid())
  workspaceId        String
  visitorId          String
  assigneeId         String?
  status             ConversationStatus @default(OPEN)
  subject            String?
  priority           Int                @default(0)
  tags               String[]
  snoozedUntil       DateTime?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  aiSummary          String?
  metadata           Json?
  createdAt          DateTime           @default(now()) @map(name: "created_at")
  updatedAt          DateTime           @updatedAt @map(name: "updated_at")
  closedAt           DateTime?

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  visitor   Visitor          @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  assignee  WorkspaceMember? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  messages  Message[]
  slaTimer  SlaTimer?

  @@index([workspaceId, status])
  @@index([workspaceId, assigneeId])
  @@index([workspaceId, lastMessageAt])
  @@map(name: "conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  type           MessageType
  body           String
  senderId       String?
  senderName     String?
  attachments    Json?
  createdAt      DateTime    @default(now()) @map(name: "created_at")
  updatedAt      DateTime    @updatedAt @map(name: "updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map(name: "messages")
}

// ─── Canned Responses ────────────────────────────────────

model CannedResponse {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  body        String
  createdById String
  createdAt   DateTime @default(now()) @map(name: "created_at")
  updatedAt   DateTime @updatedAt @map(name: "updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map(name: "canned_responses")
}

// ─── Knowledge Base Models ───────────────────────────────

model Collection {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?
  icon        String?
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now()) @map(name: "created_at")
  updatedAt   DateTime @updatedAt @map(name: "updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articles  Article[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map(name: "collections")
}

model Article {
  id              String    @id @default(cuid())
  workspaceId     String
  collectionId    String?
  title           String
  slug            String
  body            String
  excerpt         String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  authorId        String
  order           Int       @default(0)
  viewCount       Int       @default(0)
  helpfulCount    Int       @default(0)
  notHelpfulCount Int       @default(0)
  createdAt       DateTime  @default(now()) @map(name: "created_at")
  updatedAt       DateTime  @updatedAt @map(name: "updated_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, isPublished])
  @@index([workspaceId, collectionId])
  @@map(name: "articles")
}

model HelpCenterSettings {
  id           String   @id @default(cuid())
  workspaceId  String   @unique
  title        String   @default("Help Center")
  subtitle     String?
  primaryColor String   @default("#3ECF8E")
  logoUrl      String?
  createdAt    DateTime @default(now()) @map(name: "created_at")
  updatedAt    DateTime @updatedAt @map(name: "updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map(name: "help_center_settings")
}

model AiUsageLog {
  id             String   @id @default(cuid())
  workspaceId    String
  feature        String   // "reply_suggestion", "summarize", "categorize", "suggest_articles", "sentiment"
  inputTokens    Int
  outputTokens   Int
  model          String   @default("claude-sonnet-4-5-20250929")
  conversationId String?
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map(name: "ai_usage_logs")
}

// ─── Automations ────────────────────────────────────────

enum AutomationTrigger {
  CONVERSATION_CREATED
  CONVERSATION_CLOSED
  MESSAGE_RECEIVED
  CONVERSATION_UNASSIGNED_FOR
  TAG_ADDED
}

enum AutomationAction {
  ASSIGN_TO
  ADD_TAG
  REMOVE_TAG
  CHANGE_STATUS
  SEND_MESSAGE
  NOTIFY_SLACK
}

model AutomationRule {
  id          String            @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isEnabled   Boolean           @default(true)
  trigger     AutomationTrigger
  conditions  Json?             // e.g. {"tags_contain": "bug", "status": "OPEN"}
  action      AutomationAction
  actionConfig Json             // e.g. {"assigneeId": "xxx"} or {"tag": "urgent"}
  order       Int               @default(0)
  lastTriggeredAt DateTime?
  triggerCount    Int            @default(0)
  createdAt   DateTime          @default(now()) @map(name: "created_at")
  updatedAt   DateTime          @updatedAt @map(name: "updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isEnabled])
  @@map(name: "automation_rules")
}

// ─── Slack Integration ──────────────────────────────────

model SlackIntegration {
  id               String   @id @default(cuid())
  workspaceId      String   @unique
  accessToken      String
  slackTeamName    String?
  channelId        String?
  channelName      String?
  webhookUrl       String?
  botUserId        String?
  notifyOnNew      Boolean  @default(true)
  notifyOnClose    Boolean  @default(false)
  notifyOnAssign   Boolean  @default(false)
  createdAt        DateTime @default(now()) @map(name: "created_at")
  updatedAt        DateTime @updatedAt @map(name: "updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map(name: "slack_integrations")
}

// ─── Analytics Snapshots ────────────────────────────────

model AnalyticsSnapshot {
  id                    String   @id @default(cuid())
  workspaceId           String
  date                  DateTime @db.Date
  newConversations      Int      @default(0)
  closedConversations   Int      @default(0)
  totalMessages         Int      @default(0)
  avgFirstResponseMs    Int?     // milliseconds
  avgResolutionMs       Int?     // milliseconds
  visitorCount          Int      @default(0)
  createdAt             DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date])
  @@index([workspaceId, date])
  @@map(name: "analytics_snapshots")
}

// ─── SLA Policies ────────────────────────────────────────

enum SlaPriority {
  STANDARD
  MEDIUM
  HIGH
  CRITICAL
}

model SlaPolicy {
  id               String      @id @default(cuid())
  workspaceId      String
  name             String
  priority         SlaPriority
  firstResponseMs  Int         // target first response in milliseconds
  resolutionMs     Int         // target resolution in milliseconds
  isEnabled        Boolean     @default(true)
  createdAt        DateTime    @default(now()) @map(name: "created_at")
  updatedAt        DateTime    @updatedAt @map(name: "updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, priority])
  @@index([workspaceId])
  @@map(name: "sla_policies")
}

model SlaTimer {
  id                   String    @id @default(cuid())
  conversationId       String    @unique
  workspaceId          String
  policyId             String?
  priority             SlaPriority @default(STANDARD)
  firstResponseAt      DateTime?
  firstResponseMs      Int?
  resolvedAt           DateTime?
  resolutionMs         Int?
  firstResponseBreached Boolean  @default(false)
  resolutionBreached    Boolean  @default(false)
  createdAt            DateTime  @default(now()) @map(name: "created_at")
  updatedAt            DateTime  @updatedAt @map(name: "updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  policy       SlaPolicy?   @relation(fields: [policyId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([conversationId])
  @@map(name: "sla_timers")
}

